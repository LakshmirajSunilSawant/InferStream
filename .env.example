# InferStream Environment Configuration
# ============================================================
# Docker services use hostname-based URLs (kafka, redis, mlflow, api).
# For local development, override with localhost equivalents.

# ── Kafka (KRaft mode — no ZooKeeper) ────────────────────────────────────
# Docker:  kafka:9092
# Local:   localhost:9092
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_RAW_EVENTS=raw-events
KAFKA_TOPIC_FEATURES=computed-features

# ── Redis Stack (online feature store) ───────────────────────────────────
# Docker:  redis://redis:6379
# Local:   redis://localhost:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ── DuckDB (offline feature store) ───────────────────────────────────────
# Docker:  /data/inferstream.duckdb  (mounted duckdb-data volume)
# Local:   ./data/inferstream.duckdb
DUCKDB_PATH=/data/inferstream.duckdb

# ── MLflow (model registry & tracking) ───────────────────────────────────
# Docker:  http://mlflow:5000
# Local:   http://localhost:5000
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=inferstream-stock-prediction

# ── Airflow (orchestration) ───────────────────────────────────────────────
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=sqlite:////opt/airflow/airflow.db
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=<YOUR_PASSWORD>

# ── FastAPI Gateway ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RATE_LIMIT=100/minute
# Docker:  http://api:8000
# Local:   http://localhost:8000
API_URL=http://api:8000

# ── BentoML Model Server ──────────────────────────────────────────────────
BENTO_HOST=0.0.0.0
BENTO_PORT=3000
# Docker:  http://bentoml:3000
# Local:   http://localhost:3000
BENTOML_URL=http://bentoml:3000

# ── Prometheus ────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090

# ── Grafana ───────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=<YOUR_PASSWORD>
GF_SERVER_HTTP_PORT=3001

# ── Feast Feature Store ───────────────────────────────────────────────────
FEAST_REPO_PATH=/app/feature_store

# ── Model Config ──────────────────────────────────────────────────────────
MODEL_NAME=stock_predictor
DRIFT_THRESHOLD=0.2
DRIFT_CHECK_INTERVAL_HOURS=1
RETRAIN_SCHEDULE=0 2 * * *
PROMOTION_THRESHOLD=0.0

# ── Drift Report Paths ────────────────────────────────────────────────────
DRIFT_REPORT_PATH=/tmp/inferstream_drift_report.json
DRIFT_HTML_REPORT_PATH=/tmp/inferstream_drift_report.html

# ── Feature Consumer Tuning ───────────────────────────────────────────────
DUCKDB_BATCH_SIZE=100
DUCKDB_FLUSH_INTERVAL=10.0
FEATURE_COMPUTE_INTERVAL=0.5

# ── Event Producer ────────────────────────────────────────────────────────
# Note: Producer streams BTCUSDT, ETHUSDT, SOLUSDT from Binance WebSocket.
# PRODUCER_SYMBOLS is unused — symbol list is hardcoded in BINANCE_WS_URL.
PRODUCER_RATE=100
